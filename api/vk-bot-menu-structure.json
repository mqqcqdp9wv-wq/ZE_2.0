    { "id": "mat_mc_rear", "type": "text_with_keyboard", "text": "Задняя полусфера · Rayno MonoCarbon\n\nСтоимость: от 8 000 ₽\nТочная цена зависит от марки автомобиля.\n\nПлёнка не выгорает, не глушит связь. Гарантия 10+ лет.\nУстановка ~1 час, без разбора дверей.", "keyboard": { "inline": true, "buttons": [ [ {"label": "Связаться с мастером", "action": "navigate", "target": "contacts", "color": "primary"} ], [ {"label": "Подробнее о плёнке", "action": "navigate", "target": "films", "color": "secondary"}, {"label": "Назад", "action": "navigate", "target": "zone_rear", "color": "negative"} ] ] } },
    { "id": "mat_ct_rear", "type": "text_with_keyboard", "text": "Задняя полусфера · Rayno Centum\n\nCentum (прозрачная керамика) устанавливается на переднюю часть. Для задней полусферы рекомендуем MonoCarbon.", "keyboard": { "inline": true, "buttons": [ [ {"label": "Связаться с мастером", "action": "navigate", "target": "contacts", "color": "primary"} ], [ {"label": "Подробнее о плёнке", "action": "navigate", "target": "films", "color": "secondary"}, {"label": "Назад", "action": "navigate", "target": "zone_rear", "color": "negative"} ] ] } },
    { "id": "mat_mc_front", "type": "text_with_keyboard", "text": "Передние боковые · Rayno MonoCarbon\n\nСтоимость: от 4 000 ₽\n\nЗатемнение без выгорания. Без разбора дверей.", "keyboard": { "inline": true, "buttons": [ [ {"label": "Связаться с мастером", "action": "navigate", "target": "contacts", "color": "primary"} ], [ {"label": "Подробнее о плёнке", "action": "navigate", "target": "films", "color": "secondary"}, {"label": "Назад", "action": "navigate", "target": "zone_front", "color": "negative"} ] ] } },
    { "id": "mat_ct_front", "type": "text_with_keyboard", "text": "Передние боковые · Rayno Centum\n\nСтоимость: от 5 000 ₽\n\nПрозрачная атермальная плёнка — убирает жару, светопропускание 80% (по ГОСТу).", "keyboard": { "inline": true, "buttons": [ [ {"label": "Связаться с мастером", "action": "navigate", "target": "contacts", "color": "primary"} ], [ {"label": "Подробнее о плёнке", "action": "navigate", "target": "films", "color": "secondary"}, {"label": "Назад", "action": "navigate", "target": "zone_front", "color": "negative"} ] ] } },
    { "id": "mat_mc_wind", "type": "text_with_keyboard", "text": "Лобовое · Rayno MonoCarbon\n\nСтоимость: от 10 000 ₽\n\nВнимание: тёмная плёнка на лобовое может не пройти ГОСТ. Рекомендуем Centum.", "keyboard": { "inline": true, "buttons": [ [ {"label": "Связаться с мастером", "action": "navigate", "target": "contacts", "color": "primary"} ], [ {"label": "Подробнее о плёнке", "action": "navigate", "target": "films", "color": "secondary"}, {"label": "Назад", "action": "navigate", "target": "zone_wind", "color": "negative"} ] ] } },
    { "id": "mat_ct_wind", "type": "text_with_keyboard", "text": "Лобовое · Rayno Centum\n\nСтоимость: от 15 000 ₽\n\nПрозрачная атермальная плёнка. Убирает жару, проходит ГОСТ.", "keyboard": { "inline": true, "buttons": [ [ {"label": "Связаться с мастером", "action": "navigate", "target": "contacts", "color": "primary"} ], [ {"label": "Подробнее о плёнке", "action": "navigate", "target": "films", "color": "secondary"}, {"label": "Назад", "action": "navigate", "target": "zone_wind", "color": "negative"} ] ] } },
    { "id": "mat_mc_full", "type": "text_with_keyboard", "text": "Полный круг · Rayno MonoCarbon\n\nСтоимость рассчитывается мастером.\nВключает: задняя полусфера + передние боковые.\nБез разбора дверей.", "keyboard": { "inline": true, "buttons": [ [ {"label": "Связаться с мастером", "action": "navigate", "target": "contacts", "color": "primary"} ], [ {"label": "Подробнее о плёнке", "action": "navigate", "target": "films", "color": "secondary"}, {"label": "Назад", "action": "navigate", "target": "zone_full", "color": "negative"} ] ] } },
    { "id": "mat_ct_full", "type": "text_with_keyboard", "text": "Полный круг · Rayno Centum\n\nСтоимость рассчитывается индивидуально мастером.", "keyboard": { "inline": true, "buttons": [ [ {"label": "Связаться с мастером", "action": "navigate", "target": "contacts", "color": "primary"} ], [ {"label": "Подробнее о плёнке", "action": "navigate", "target": "films", "color": "secondary"}, {"label": "Назад", "action": "navigate", "target": "zone_full", "color": "negative"} ] ] } },



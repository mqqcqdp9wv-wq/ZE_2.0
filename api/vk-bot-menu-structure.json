       "keyboard": {
         "inline": true,
         "buttons": [
           [ {"label": "Почему выбрать Rayno?", "action": "navigate", "target": "faq_quality_why"} ],
           [ {"label": "Выгорит ли цвет?", "action": "navigate", "target": "faq_quality_color"} ],
           [ {"label": "Как принимать работу?", "action": "navigate", "target": "faq_quality_iwfa"} ],
